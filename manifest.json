{
  "manifest_version": 3,
  "name": "Waveshare Calendar Builder",
  "version": "1.2",
  "description": "Build and export weekly calendar BMPs for Waveshare 7.3\" e-paper displays",
  "action": {
    "default_title": "Waveshare Calendar Builder",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://www.googleapis.com/",
    "https://accounts.google.com/",
    "https://api.anthropic.com/"
  ],
  "oauth2": {
    "client_id": "9684360182-k0i50h3silgn3le8rm6d5lcgt1721bgj.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/calendar.readonly"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
